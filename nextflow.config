/*
================================================================================
  Nextflow Configuration
  scRNA-seq ACP Pipeline
================================================================================
*/

manifest {
    name        = 'scRNA-ACP-pipeline'
    author      = 'Nischay Patel'
    description = 'Comparative single-cell analysis of ACP and tooth developmental programs'
    version     = '1.0.0'
    nextflowVersion = '>=23.0.0'
}

// ── Default parameters ────────────────────────────────────────────────────────
params {
    data_dir  = "data"
    outdir    = "results"
    seed      = 9867
}

// ── Process defaults ──────────────────────────────────────────────────────────
process {
    cpus   = 4
    memory = '16 GB'
    time   = '4 h'

    withName: 'ACP_QC' {
        memory = '8 GB'
        cpus   = 2
    }
    withName: 'ACP_INTEGRATION' {
        memory = '32 GB'
        cpus   = 8
        time   = '8 h'
    }
    withName: 'SCIMILARITY_PREP' {
        memory = '16 GB'
        cpus   = 4
    }
    withName: 'ACP_PERIO_INTEGRATION|ACP_TOOTH_INTEGRATION' {
        memory = '32 GB'
        cpus   = 8
        time   = '8 h'
    }
    withName: 'ACP_PERIO_DOWNSTREAM' {
        memory = '16 GB'
        cpus   = 4
    }
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
        process.container = 'nischaypatel/scrna-acp-pipeline:latest'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'nischaypatel/scrna-acp-pipeline:latest'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    test {
        params.data_dir = "test_data"
        params.outdir   = "test_results"
        process.cpus    = 2
        process.memory  = '4 GB'
    }
}

// ── Execution report ──────────────────────────────────────────────────────────
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}
